# If / else branching
int score = 72;

if (score >= 90) {
    print("Grade: A");
} else {
    if (score >= 75) {
        print("Grade: B");
    } else {
        if (score >= 60) {
            print("Grade: C");
        } else {
            print("Grade: F");
        }
    }
}

# Braceless if
int x = 5;
if (x > 0) print("x is positive");

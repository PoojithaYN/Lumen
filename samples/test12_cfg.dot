digraph CFG {
  rankdir=TB;
  node [shape=box, fontname="Courier", fontsize=10];
  "ENTRY" [label="ENTRY\nprint(exprs=[string(value='Multiplicatio\nassign(name='r', value=number(value=1.0)\nlive: {}"];
  "while_cond_1" [label="while_cond_1\nwhile(cond=binop(operator='<=', left=var\nlive: {r}"];
  "while_body_1" [label="while_body_1"];
  "while_exit_1" [label="while_exit_1\nprint(exprs=[string(value='Pairs where i\nassign(name='count', value=number(value=\nassign(name='i', value=number(value=1.0)\nlive: {}"];
  "while_cond_5" [label="while_cond_5\nwhile(cond=binop(operator='<=', left=var\nlive: {count,i}"];
  "while_body_5" [label="while_body_5"];
  "while_exit_5" [label="while_exit_5\nprint(exprs=[string(value='Total pairs:'\nlive: {count}"];

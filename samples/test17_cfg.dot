  "while_body_4" [label="while_body_4"];
  "while_exit_4" [label="while_exit_4\nprint(exprs=[string(value='Sum of square\nfuncdef(name='compute', params=['n'], pa\nfuncdef(name='compute2', params=['n'], p\nfuncdef(name='outer_fn', params=['val'],\n...+4 more\nlive: {total}"];

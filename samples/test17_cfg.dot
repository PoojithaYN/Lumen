digraph CFG {
  rankdir=TB;
  node [shape=box, fontname="Courier", fontsize=10];
  "ENTRY" [label="ENTRY\nassign(name='x', value=number(value=100.\nprint(exprs=[string(value='Outer x:'), n\nif(cond=bool(value=True), then_body=[ass\nlive: {}"];
  "then_1" [label="then_1"];
  "merge_1" [label="merge_1\nassign(name='total', value=number(value=\nassign(name='i', value=number(value=0.0)\nlive: {}"];

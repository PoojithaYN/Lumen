digraph CFG {
  rankdir=TB;
  node [shape=box, fontname="Courier", fontsize=10];
  "ENTRY" [label="ENTRY\ntype_alias(alias='Count', base='int')\ntype_alias(alias='Score', base='float')\nassign(name='MAX_ITEMS', value=number(va\nassign(name='PI', value=number(value=3.1\n...+7 more\nlive: {}"];

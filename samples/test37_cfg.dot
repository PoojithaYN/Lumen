digraph CFG {
  rankdir=TB;
  node [shape=box, fontname="Courier", fontsize=10];
  "ENTRY" [label="ENTRY\nfuncdef(name='level_sum', params=['depth\nfuncdef(name='nodes_at_depth', params=['\nassign(name='max_d', value=number(value=\nassign(name='__t1', value=call(name='lev\n...+17 more\nlive: {}"];
  "while_cond_1" [label="while_cond_1\nwhile(cond=binop(operator='<=', left=var\nlive: {d}"];
  "while_body_1" [label="while_body_1"];
  "while_exit_1" [label="while_exit_1\nassign(name='grand_total', value=number(\nassign(name='dd', value=number(value=0.0\nlive: {}"];
  "while_cond_5" [label="while_cond_5\nwhile(cond=binop(operator='<=', left=var\nlive: {dd,grand_total}"];
  "while_body_5" [label="while_body_5"];
  "while_exit_5" [label="while_exit_5\nprint(exprs=[string(value='Total nodes i\nlive: {grand_total}"];
  "EXIT" [label="EXIT"];
  "ENTRY" -> "while_cond_1";
  "while_cond_1" -> "while_body_1";
  "while_cond_1" -> "while_exit_1";
  "while_body_1" -> "while_cond_1";
  "while_exit_1" -> "while_cond_5";
  "while_cond_5" -> "while_body_5";
  "while_cond_5" -> "while_exit_5";
  "while_body_5" -> "while_cond_5";
  "while_exit_5" -> "EXIT";
}
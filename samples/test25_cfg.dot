digraph CFG {
  rankdir=TB;
  node [shape=box, fontname="Courier", fontsize=10];
  "ENTRY" [label="ENTRY\nfuncdef(name='hanoi_moves', params=['n']\nfuncdef(name='power2', params=['n'], par\nassign(name='i', value=number(value=1.0)\nlive: {}"];
  "while_cond_1" [label="while_cond_1\nwhile(cond=binop(operator='<=', left=var\nlive: {i}"];
  "while_body_1" [label="while_body_1"];
  "while_exit_1" [label="while_exit_1"];
  "EXIT" [label="EXIT"];
  "ENTRY" -> "while_cond_1";
  "while_cond_1" -> "while_body_1";
  "while_cond_1" -> "while_exit_1";
  "while_body_1" -> "while_cond_1";
  "while_exit_1" -> "EXIT";
}
digraph CFG {
  rankdir=TB;
  node [shape=box, fontname="Courier", fontsize=10];
  "ENTRY" [label="ENTRY\narray_decl(name='primes', elem_type='int\nassign(name='idx', value=number(value=0.\nlive: {}"];
  "while_cond_1" [label="while_cond_1\nwhile(cond=binop(operator='<', left=var(\nlive: {idx}"];
  "while_body_1" [label="while_body_1"];
  "while_exit_1" [label="while_exit_1\narray_decl(name='temps', elem_type='floa\nassign(name='sum', value=number(value=0.\nassign(name='n', value=number(value=0.0)\nlive: {}"];
  "while_cond_5" [label="while_cond_5\nwhile(cond=binop(operator='<', left=var(\nlive: {n,sum}"];
  "while_body_5" [label="while_body_5"];
  "while_exit_5" [label="while_exit_5\nprint(exprs=[string(value='Sum of temps:\nlive: {sum}"];
  "EXIT" [label="EXIT"];
  "ENTRY" -> "while_cond_1";
  "while_cond_1" -> "while_body_1";
  "while_cond_1" -> "while_exit_1";
  "while_body_1" -> "while_cond_1";
  "while_exit_1" -> "while_cond_5";
  "while_cond_5" -> "while_body_5";
  "while_cond_5" -> "while_exit_5";
  "while_body_5" -> "while_cond_5";
  "while_exit_5" -> "EXIT";
}
def factorial(int n) {
    if (n <= 1) { return 1; }
    return n * factorial(n - 1);
}

def fib(int n) {
    if (n <= 0) { return 0; }
    if (n == 1) { return 1; }
    return fib(n - 1) + fib(n - 2);
}

int i = 1;
while (i <= 7) {
    print(i, "! =", factorial(i));
    i = i + 1;
}

int j = 0;
while (j <= 8) {
    print("fib(", j, ") =", fib(j));
    j = j + 1;
}

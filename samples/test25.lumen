def hanoi_moves(int n) {
    if (n == 0) { return 0; }
    if (n == 1) { return 1; }
    return 2 * hanoi_moves(n - 1) + 1;
}

def power2(int n) {
    if (n == 0) { return 1; }
    return 2 * power2(n - 1);
}

int i = 1;
while (i <= 10) {
    int moves    = hanoi_moves(i);
    int expected = power2(i) - 1;
    print("Hanoi(", i, ") = ", moves, "  (2^n-1 =", expected, ")");
    i = i + 1;
}

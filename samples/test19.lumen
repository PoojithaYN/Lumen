int a = 3 + 5;
int b = 10 - 4;
int c = 3 * 4;
int d = a + b;
int e = a * 1;
int f = b + 0;
int g = c - 0;
int h = 0 + a;

print("a = 3+5   =", a);
print("b = 10-4  =", b);
print("c = 3*4   =", c);
print("d = a+b   =", d);
print("e = a*1   =", e);
print("f = b+0   =", f);
print("g = c-0   =", g);
print("h = 0+a   =", h);

int val = 7;
int dbl = val * 2;
print("7 * 2 (strength reduction) =", dbl);

int base  = 10;
int limit = 5;
int prod  = base * limit;
print("10 * 5 propagated =", prod);

int i = 0;
int sum = 0;
while (i < 5) {
    sum = sum + i;
    i = i + 1;
}
print("Sum 0+1+2+3+4 =", sum);

int x1 = 2 + 3;
int x2 = x1 * 2;
int x3 = x2 + x1;
print("x1=5, x2=10, x3=15 :", x1, x2, x3);

digraph CFG {
  rankdir=TB;
  node [shape=box, fontname="Courier", fontsize=10];
  "ENTRY" [label="ENTRY\narray_decl(name='numbers', elem_type='in\nassign(name='sum', value=number(value=0.\nassign(name='i', value=number(value=0.0)\nlive: {}"];
  "while_cond_1" [label="while_cond_1\nwhile(cond=binop(operator='<', left=var(\nlive: {i,sum}"];
  "while_body_1" [label="while_body_1"];
  "while_exit_1" [label="while_exit_1\nprint(exprs=[string(value='Sum of array:\nlive: {sum}"];
  "EXIT" [label="EXIT"];
  "ENTRY" -> "while_cond_1";
  "while_cond_1" -> "while_body_1";
  "while_cond_1" -> "while_exit_1";
  "while_body_1" -> "while_cond_1";
  "while_exit_1" -> "EXIT";
}
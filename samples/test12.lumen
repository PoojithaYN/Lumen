print("Multiplication table 4x4:");
int r = 1;
while (r <= 4) {
    int c = 1;
    while (c <= 4) {
        int prod = r * c;
        print(r, "x", c, "=", prod);
        c = c + 1;
    }
    r = r + 1;
}

print("Pairs where i+j = 7:");
int count = 0;
int i = 1;
while (i <= 6) {
    int j = 1;
    while (j <= 6) {
        int s = i + j;
        if (s == 7) {
            print("(", i, ",", j, ")");
            count = count + 1;
        }
        j = j + 1;
    }
    i = i + 1;
}
print("Total pairs:", count);

digraph CFG {
  rankdir=TB;
  node [shape=box, fontname="Courier", fontsize=10];
  "ENTRY" [label="ENTRY\nfuncdef(name='day_name', params=['d'], p\nassign(name='k', value=number(value=1.0)\nlive: {}"];
  "while_cond_1" [label="while_cond_1\nwhile(cond=binop(operator='<=', left=var\nlive: {k}"];
  "while_body_1" [label="while_body_1"];
  "while_exit_1" [label="while_exit_1\nassign(name='code', value=number(value=2\nswitch(expr=var(name='code'), cases=[(nu\nlive: {}"];
  "then_5" [label="then_5"];
  "merge_5" [label="merge_5"];
  "EXIT" [label="EXIT"];
  "ENTRY" -> "while_cond_1";
  "while_cond_1" -> "while_body_1";
  "while_cond_1" -> "while_exit_1";
  "while_body_1" -> "while_cond_1";
  "while_exit_1" -> "then_5";
  "while_exit_1" -> "merge_5";
  "then_5" -> "merge_5";
  "merge_5" -> "EXIT";
}
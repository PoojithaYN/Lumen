digraph CFG {
  rankdir=TB;
  node [shape=box, fontname="Courier", fontsize=10];
  "ENTRY" [label="ENTRY\nassign(name='count', value=number(value=\nassign(name='total', value=number(value=\nlive: {}"];
  "while_cond_1" [label="while_cond_1\nwhile(cond=binop(operator='<', left=var(\nlive: {count,total}"];
  "while_body_1" [label="while_body_1"];
  "while_exit_1" [label="while_exit_1\nprint(exprs=[string(value='Final total:'\nlive: {total}"];
  "EXIT" [label="EXIT"];
  "ENTRY" -> "while_cond_1";
  "while_cond_1" -> "while_body_1";
  "while_cond_1" -> "while_exit_1";
  "while_body_1" -> "while_cond_1";
  "while_exit_1" -> "EXIT";
}